{
  "name": "jamony",
  "version": "0.1.0-alpha",
  "description": "jamony — 音乐人远程合奏桌面应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.jamony.app",
    "productName": "jamony",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "loading.html",
      "icon.png",
      "package.json"
    ],
    "extraResources": [],
    "mac": {
      "target": ["dmg"],
      "icon": "icon.png",
      "category": "public.app-category.music",
      "extraResources": [
        {
          "from": "jamsoul.app",
          "to": "jamsoul.app"
        }
      ]
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.png",
      "extraResources": [
        {
          "from": "../dist/jamsoul-bin",
          "to": "jamsoul-bin",
          "filter": ["**/*"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  }
}
